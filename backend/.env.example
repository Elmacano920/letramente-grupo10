# Letramente — Variables de Entorno Backend
# Copia este archivo como .env y rellena los valores

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# 1. Ve a https://cloud.mongodb.com
# 2. Crea una cuenta gratis (Free Tier)
# 3. Crea un cluster (M0 Free)
# 4. En "Database Access": crea usuario y contraseña
# 5. En "Network Access": agrega tu IP (o 0.0.0.0/0 para desarrollo)
# 6. En "Database" > Connect > Drivers: copia el string y pégalo aquí
MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/letramente?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=letramente_grupo10_secret_key_cambiar_en_produccion
JWT_EXPIRES_IN=7d

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Frontend URL (para CORS) ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
