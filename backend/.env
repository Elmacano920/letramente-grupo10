# =============================================
# LectoPlay Backend — Variables de Entorno
# Copia este archivo como .env y ajusta los valores
# =============================================

# Puerto del servidor
PORT=3001

# Clave secreta para JWT (cámbiala en producción)
JWT_SECRET=lectoplay_super_secret_key_grupo10_2024

# Duración del token JWT
JWT_EXPIRES_IN=7d

# Entorno: development | production
NODE_ENV=development

# Ruta de la base de datos SQLite
DB_PATH=./database
